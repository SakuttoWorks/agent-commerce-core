# === Python Core (Build & Cache) ===
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
build/
dist/
*.egg-info/
.installed.cfg
*.egg
MANIFEST

# === Environments (Critical Security: Zero Trust) ===
# Blocks private keys, API secrets, and Polar.sh tokens
.env
.env.local
.env.*
.envrc
.venv
env/
venv/
ENV/

# === Cloud & Secrets (Safety Net) ===
# Explicitly block Google Cloud Service Account Keys
*service-account*.json
*gcp-key*.json
*.pem
*.key

# === Editor / IDE (VS Code Shared Config) ===
# 2026 Standard: Share settings/tasks, ignore local history
.vscode/*
!.vscode/settings.json
!.vscode/tasks.json
!.vscode/launch.json
!.vscode/extensions.json
.history/
.idea/

# === Testing / Linting (Dev Health) ===
.pytest_cache/
.tox/
.nox/
.coverage
.cache
.ruff_cache/
.mypy_cache/
htmlcov/

# === Runtime / Logs (Privacy & Compliance) ===
# Prevent uploading local logs or scraped data (GDPR/EU AI Act)
*.log
logs/
data/
temp/
output/
*.sqlite
*.db

# === Operating System ===
.DS_Store
Thumbs.db
desktop.ini

# === Legacy / Project Specific (Layer B Cleanup) ===
# Prevent accidental inclusion of legacy artifacts into the repository
supabase/
mcp.json
llms.txt
